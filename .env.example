# ──────────────────────────────────────────────────────────────────────────────
# FitNex AI — Global Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────

# --- Frontend (React + Vite) ---
# Copy to .env in the root directory
# For production, set these in your hosting provider (Vercel/Netlify)

# FastAPI Backend URL (No trailing slash)
# Development: http://localhost:8000
# Production : https://api.fitnex.ai
VITE_AI_URL=http://localhost:8000

# --- Backend (FastAPI) ---
# These should be set in python_services/.env for local development
# or in your backend hosting provider (Railway/Render)

# Database Connection String
# SQLite: sqlite+aiosqlite:///./fitnex.db
# Production Supabase Transaction Pooler (port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.XXXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Security
JWT_SECRET=generate-a-long-random-string-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# CORS Allowed Origins (Comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SMTP Email (for OTP verification)
# Leave SMTP_USER and SMTP_PASS empty in dev — OTP codes will be logged to the console.
# Production: use a Gmail App Password or an SMTP relay (SendGrid, Brevo, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
