# FitNex AI — Environment Variables
# Copy this file to .env and fill in your values.

# database (Supabase PostgreSQL via Transaction Pooler, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.XXXXX:PASSWORD@aws-1-eu-north-1.pooler.supabase.com:6543/postgres

# JWT (use a long random string in production)
JWT_SECRET=CHANGE-ME-USE-A-SECURE-RANDOM-STRING
JWT_EXPIRE_HOURS=72

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (Frontend Serverless Proxy)
# In production, the backend fires an HTTP request to the Vercel API.
# You only need to configure SMTP_USER and SMTP_PASS inside your Vercel Dashboard!

# frontend URL (used in password reset email links)
FRONTEND_URL=http://localhost:5173
